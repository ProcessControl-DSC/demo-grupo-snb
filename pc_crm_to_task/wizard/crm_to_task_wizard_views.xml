<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_crm_lead_to_task_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.to.task.wizard.form</field>
        <field name="model">crm.lead.to.task.wizard</field>
        <field name="arch" type="xml">
            <form string="Create task from lead">
                <sheet>
                    <group>
                        <field name="lead_id" invisible="1"/>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="stage_id"/>
                        <field name="user_ids" widget="many2many_tags"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                        <field name="partner_id"/>
                        <field name="date_deadline"/>
                        <field name="priority" widget="priority"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description_page">
                            <field name="description"/>
                        </page>
                        <page string="Transfer and notifications" name="options_page">
                            <group string="Move from lead to task">
                                <field name="transfer_messages"/>
                                <field name="transfer_attachments"/>
                                <field name="transfer_followers"/>
                            </group>
                            <group string="Notifications">
                                <field name="send_mail"/>
                                <field name="create_activity"/>
                            </group>
                            <group string="Lead">
                                <field name="archive_lead"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_create_task"
                            type="object"
                            string="Create task"
                            class="btn-primary"/>
                    <button special="cancel"
                            string="Cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_crm_lead_to_task_wizard" model="ir.actions.act_window">
        <field name="name">Create task from lead</field>
        <field name="res_model">crm.lead.to.task.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
