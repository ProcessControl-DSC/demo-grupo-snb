<odoo>
    <record id="product_category_form_inherit_last_price" model="ir.ui.view">
        <field name="name">product.category.form.pc.last.price</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='property_cost_method']" position="after">
                <field name="last_price_update_enabled"/>
            </xpath>
        </field>
    </record>
</odoo>
